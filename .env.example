# ──────────────────────────────────────────────────────────────
# E-COMMERCE CHECKOUT BACKEND — Environment Variables
# 
# Copy this file to .env for local development.
# On AWS App Runner (production), set these as environment variables
# in the service configuration. NEVER commit real values to git.
# 
# All variables below are REQUIRED.
# ──────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=production
LOG_LEVEL=info
APP_URL=https://checkout.example.com

# ─────────────────────────────────────────────────────────────
# SHOPIFY
# ─────────────────────────────────────────────────────────────
# Generate in Shopify Admin → Apps & integrations → Develop apps

SHOPIFY_SHOP_DOMAIN=myshop.myshopify.com
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_STOREFRONT_TOKEN=your_storefront_token_here
SHOPIFY_ADMIN_TOKEN=your_admin_token_here

# ─────────────────────────────────────────────────────────────
# RAZORPAY (Payment Gateway)
# ─────────────────────────────────────────────────────────────
# Found in: Razorpay Dashboard → Settings → API Keys

RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─────────────────────────────────────────────────────────────
# META WHATSAPP (OTP Delivery)
# ─────────────────────────────────────────────────────────────
# Register at: https://developers.facebook.com/
# Create a WhatsApp Business App

META_WHATSAPP_TOKEN=your_whatsapp_api_token
META_PHONE_NUMBER_ID=your_phone_number_id

# ─────────────────────────────────────────────────────────────
# SUPABASE (Database)
# ─────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
